{% extends "layouts/layout.html.twig" %}
{% block title %}
    <title>Page not Found</title>
{% endblock %}

{% block content %}
    <main class="flex items-center justify-center">
        <div class="text-center px-6 mt-28">

            <h1 class="text-9xl font-extrabold text-zinc-800 tracking-tight">
                404
            </h1>

            <h2 class="mt-4 text-3xl font-semibold text-zinc-700">
                Page not found
            </h2>

            <p class="mt-2 text-zinc-500 max-w-md mx-auto">
                Oops! The page you are looking for does not exist or has been moved.
            </p>

            <div class="mt-8 flex justify-center gap-4">
                <a href="/"
                   class="px-6 py-3 rounded-lg bg-blue-600 text-white font-medium hover:bg-blue-700 transition shadow-sm">
                    <i class="fa-solid fa-home mr-2"></i>
                    Back to homepage
                </a>

                <a href="javascript:history.back()"
                   class="px-6 py-3 rounded-lg bg-white border border-zinc-200 text-zinc-700 font-medium hover:bg-zinc-100 transition">
                    Go back
                </a>
            </div>

            <div class="mt-12 text-sm text-zinc-400">
                Error code: 404
            </div>

        </div>
    </main>
{% endblock %}