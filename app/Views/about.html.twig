{% extends "layouts/layout.html.twig" %}
{% block title %}
    <title>About</title>
{% endblock %}

{% block content %}
    <main class="flex flex-col justify-center items-center text-center mt-20">
        <div class="max-w-2xl">
            <h1 class="text-6xl font-bold text-zinc-800">About <span class="text-blue-500">Taskey</span></h1>

            <p class="mt-6 text-zinc-600 leading-relaxed">
                Taskey is a simple and efficient
                <span class="relative inline-block before:absolute before:-inset-1 before:block before:-skew-y-3 before:bg-blue-500">
                    <span class="relative text-white">task manager</span>
                </span>
                that helps you organize your daily work and personal tasks.
                With Taskey you can easily create, read, update, and delete tasks, making it straightforward to keep track
                of everything you need to do.
            </p>

            <p class="mt-4 text-zinc-600 leading-relaxed">
                The goal of Taskey is to provide a clean and
                <span class="relative inline-block before:absolute before:-inset-1 before:block before:-skew-y-3 before:bg-blue-500">
                    <span class="relative text-white">minimal interface</span>
                </span>
                where productivity comes first.
                Instead of complicated features, Taskey focuses on the core functionality of task management so
                you can quickly add tasks, manage them, and stay organized without distractions.
            </p>

            <p class="mt-4 text-zinc-600 leading-relaxed">
                Taskey is also an
                <span class="relative inline-block before:absolute before:-inset-1 before:block before:-skew-y-3 before:bg-blue-500">
                    <span class="relative text-white">open-source</span>
                </span>
                project built with the PHP Maestro framework. This means developers
                can explore the source code, contribute improvements, and learn how the application works
                behind the scenes.
            </p>
        </div>

        <div class="mt-20">
            <a href="https://github.com/Arootsy/Taskey" target="_blank" class="border border-zinc-200 px-6 py-3 shadow-lg rounded-md hover:cursor-pointer"> <i class="fa-brands fa-github"></i> Repository</a>
        </div>
    </main>

{% endblock %}