<el-dialog>
    <dialog id="dialog-open{{ task.id is defined ? '-' ~ task.id : '' }}" class="fixed inset-0 size-auto max-h-none max-w-none overflow-y-auto bg-transparent backdrop:bg-black/40">
        <div class="flex min-h-full items-center justify-center p-4 backdrop-blur-sm">
            <el-dialog-panel class="relative w-full max-w-lg transform overflow-hidden rounded-2xl bg-white text-left shadow-2xl outline outline-white/10 transition-all">
                <form method="POST" action="{{ route ?? "tasks/create" }}" class="text-sm text-gray-300">
                    <div class="p-6">
                        <div class="flex items-start gap-4">
                            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-blue-500/10">
                                <svg xmlns="http://www.w3.org/2000/svg"
                                     class="h-6 w-6 text-blue-400"
                                     fill="none"
                                     viewBox="0 0 24 24"
                                     stroke="currentColor"
                                     stroke-width="1.5">
                                    <path stroke-linecap="round"
                                          stroke-linejoin="round"
                                          d="M9 5h6m-7 4h8m-8 4h5m5-8v14a2 2 0 01-2 2H8a2 2 0 01-2-2V5a2 2 0 012-2h3.5l1 1h3.5a2 2 0 012 2z"/>
                                </svg>
                            </div>

                            <div class="flex-1">
                                <h3 class="text-lg font-semibold mb-4 text-gray-700">
                                    {{ labels.title ?? "Create new task" }}
                                </h3>

                                <div class="space-y-6">

                                    <!-- Title -->
                                    <div>
                                        <label class="block text-sm font-medium text-gray-400 mb-1">
                                            Title
                                        </label>

                                        <input required value="{{ task.title }}" type="text" id="title" name="title" placeholder="Enter task title..." class="w-full rounded-lg bg-gray-200 border border-zinc-300 px-3 py-2 text-gray-700 placeholder-gray-500 focus:border-blue-500 focus:ring-2 focus:ring-blue-500/30 outline-none transition resize-none"/>
                                    </div>

                                    <!-- Description -->
                                    <div>
                                        <label class="block text-sm font-medium text-gray-400 mb-1">
                                            Description
                                        </label>

                                        <textarea
                                                id="description"
                                                name="description"
                                                value="hasdf"
                                                rows="4"
                                                placeholder="Describe the task..."
                                                class="w-full rounded-lg bg-gray-200 border border-zinc-300 px-3 py-2 text-gray-700 placeholder-gray-500 focus:border-blue-500 focus:ring-2 focus:ring-blue-500/30 outline-none transition resize-none"
                                        >{{ task.description }}</textarea>
                                    </div>

                                    <div>
                                        <div class="flex place-content-between">
                                            <label class="block text-sm font-medium text-gray-400 mb-1">Progress</label>
                                            <p id="progressvalue">{{ task.progress ?? '50' }}%</p>
                                        </div>
                                        <input value="{{ task.progress }}" class="w-full" type="range" id="progress" name="progress" min="0" max="100" />
                                    </div>

                                    <div>
                                        <label class="block text-sm font-medium text-gray-400 mb-1">Priority</label>
                                        {% include 'select.html.twig' with { 'title': 'priority', 'options': priorities, 'default': task.priority, 'loopIndex': 'index0'} %}
                                    </div>

                                    <div>
                                        <label class="block text-sm font-medium text-gray-400 mb-1">Status</label>
                                        {% include 'select.html.twig' with { 'title': 'status', 'options': statuses, 'default': task.status, 'loopIndex': 'index0'} %}
                                    </div>

                                    {% if task %}
                                        <input id="id" name="id" type="hidden" value="{{ task.id }}">
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Actions -->
                    <div class="flex items-center justify-end gap-3 border-t border-white/10 px-6 py-4">
                        <button
                                type="button"
                                command="close"
                                commandfor="{{ task.id ? 'dialog-open-' ~ task.id : 'dialog-open' }}"
                                class="rounded-lg bg-gray-700 px-4 py-2 text-sm font-medium text-gray-200 hover:bg-gray-600 transition cursor-pointer"
                        >
                            Cancel
                        </button>

                        <button
                                type="submit"
                                command="close"
                                commandfor="dialog-open"
                                id="submitbutton"
                                class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-500 transition cursor-pointer"
                        >
                            {{ labels.submit ?? "Create Task" }}
                        </button>
                    </div>

                </form>
            </el-dialog-panel>
        </div>
    </dialog>
</el-dialog>
