<el-dialog>
    <dialog id="dialog-delete-{{ task.id }}" class="fixed inset-0 size-auto max-h-none max-w-none overflow-y-auto bg-transparent backdrop:bg-black/40 hover:cursor-default">
        <div class="flex min-h-full items-center justify-center p-4 backdrop-blur-sm">
            <el-dialog-panel class="relative w-full max-w-lg transform overflow-hidden rounded-2xl bg-white text-left shadow-2xl outline outline-white/10 transition-all">
                <form method="POST" action="tasks/{{ task.id }}/delete" class="text-sm text-gray-300">
                    <div class="p-6">
                        <div class="flex items-start gap-4">
                            <!-- Icon -->
                            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-red-500/10">
                                <svg xmlns="http://www.w3.org/2000/svg"
                                     class="h-6 w-6 text-red-400"
                                     fill="none"
                                     viewBox="0 0 24 24"
                                     stroke="currentColor"
                                     stroke-width="1.5">
                                    <path stroke-linecap="round"
                                          stroke-linejoin="round"
                                          d="M9 5h6m-7 4h8m-8 4h5m5-8v14a2 2 0 01-2 2H8a2 2 0 01-2-2V5a2 2 0 012-2h3.5l1 1h3.5a2 2 0 012 2z"/>
                                </svg>
                            </div>

                            <div class="flex-1">
                                <h3 class="text-lg font-semibold mb-4 text-gray-700">
                                    Are you sure?
                                </h3>

                                <p>Are you sure you wan't to delete {{ task.title }}?</p>
                            </div>
                        </div>
                    </div>

                    <!-- Actions -->
                    <div class="flex items-center justify-end gap-3 border-t border-white/10 px-6 py-4">
                        <button
                                type="button"
                                command="close"
                                commandfor="dialog-delete-{{ task.id }}"
                                class="rounded-lg bg-gray-700 px-4 py-2 text-sm font-medium text-gray-200 hover:bg-gray-600 transition hover:cursor-pointer"
                        >
                            Cancel
                        </button>

                        <button
                                type="submit"
                                command="close"
                                commandfor="dialog-delete-{{ task.id }}"
                                class="rounded-lg bg-red-600 px-4 py-2 text-sm font-semibold text-white hover:bg-red-500 transition hover:cursor-pointer"
                        >
                            Delete
                        </button>
                    </div>

                </form>
            </el-dialog-panel>
        </div>
    </dialog>
</el-dialog>