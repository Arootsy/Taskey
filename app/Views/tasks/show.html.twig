{% extends "layouts/layout.html.twig" %}

{% block title %}
    <title>Task #{{ task.id }}</title>
{% endblock %}

{% block content %}
    <div class="p-24">
        <div class="max-w-4xl mx-auto">

            <div class="flex place-content-between">
                <a href="/tasks"
                   class="text-sm text-gray-500 hover:text-gray-700 mb-6 inline-flex items-center gap-2 hover:underline">
                    ← Back to tasks
                </a>

                {% include "modals/create-task.html.twig" with { 'task': task, 'labels': {
                    title: 'Edit Task',
                    submit: 'Save'
                }, 'route': 'tasks/update' } %}

                <button command="show-modal" commandfor="dialog-open-{{ task.id }}" class="text-sm text-gray-500 hover:text-gray-700 hover:cursor-pointer mb-6 inline-flex items-center hover:underline gap-1">
                    Edit task
                </button>
            </div>

            <div class="bg-white shadow-xl rounded-2xl overflow-hidden">
                <div class="p-6 border-b gap-6 border-zinc-300 flex justify-between items-start mx-6">
                    <div class="-mx-6">
                        <h1 class="text-2xl font-bold text-gray-800">
                            {{ task.title }}
                        </h1>

                        <p class="text-sm text-gray-400 mt-1">
                            Task #{{ task.id }}
                        </p>
                    </div>

                    <div class="flex gap-2 -mx-6">
                        <span class="px-3 py-1 text-xs font-semibold rounded-full
                            bg-{{ priorityColours[task.priority] }}-100
                            text-{{ priorityColours[task.priority] }}-600">
                            {{ priorities[task.priority]|capitalize }}
                        </span>

                        <span class="px-3 py-1 text-xs font-semibold rounded-full
                            bg-{{ statusColours[task.status] }}-100
                            text-{{ statusColours[task.status] }}-600">
                            {{ statuses[task.status]|capitalize }}
                        </span>

                    </div>
                </div>

                <div class="p-6 space-y-6">
                    <div>
                        <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-2">
                            Description
                        </h3>

                        <p class="text-gray-700 leading-relaxed">
                            {{ task.description }}
                        </p>
                    </div>

                    <div>
                        <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-2">
                            Progress
                        </h3>

                        <div class="w-full bg-gray-200 rounded-full h-3">
                            <div class="bg-blue-500 h-3 rounded-full"
                                 style="width: {{ task.progress }}%">
                            </div>
                        </div>

                        <span class="text-xs text-gray-500">
                        {{ task.progress }}% complete
                    </span>
                    </div>

                    <div class="grid grid-cols-2 gap-6 pt-4 border-t border-zinc-300">
                        <div>
                            <h4 class="text-xs text-gray-400 uppercase mb-1">
                                Created
                            </h4>

                            <p class="text-gray-700">
                                {{ task.createdAt|date('d M Y') }}
                            </p>
                        </div>
                        <div>
                            <h4 class="text-xs text-gray-400 uppercase mb-1">
                                Completed
                            </h4>

                            <p class="text-gray-700">
                                {{ task.completedAt|date('d M Y') ?: 'Not completed' }}
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}