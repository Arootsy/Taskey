{% extends "layouts/layout.html.twig" %}
{% block title %}
    <title>Tasks</title>
{% endblock %}

{% block content %}
    <script src="https://cdn.jsdelivr.net/npm/@tailwindplus/elements@1" type="module"></script>

    <ol class="flex items-center whitespace-nowrap px-24 py-12">
        <li class="inline-flex items-center">
            <a class="flex items-center text-sm text-muted-foreground-1 hover:text-primary-focus focus:outline-hidden focus:text-primary-focus" href="/">
                Home
            </a>
            <svg class="shrink-0 mx-2 size-4 text-muted-foreground" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m9 18 6-6-6-6"/>
            </svg>
        </li>
        <li class="inline-flex items-center text-sm font-semibold text-foreground truncate" aria-current="page">
            Tasks
        </li>
    </ol>

    <div class="px-24 py-8">
        <div class="flex justify-between mb-6">
            <h1 class="text-3xl font-bold text-gray-800">Tasks</h1>
            <button command="show-modal" commandfor="dialog-open" class="bg-blue-500 text-white px-6 py-3 rounded-md hover:cursor-pointer hover:bg-blue-600 duration-500">
                Create
            </button>
        </div>

        <div class="bg-white shadow-lg rounded-2xl overflow-hidden">
            <div class="overflow-x-auto">

                <table class="table-auto w-full text-sm text-left text-gray-600">

                    <thead class="bg-gray-100 text-xs uppercase tracking-wider text-gray-700">
                    <tr>
                        <th class="px-4 py-3">ID</th>
                        <th class="px-4 py-3">Title</th>
                        <th class="px-4 py-3">Priority</th>
                        <th class="px-4 py-3">Status</th>
                        <th class="px-4 py-3">Progress</th>
                        <th class="px-4 py-3">Created</th>
                        <th class="px-4 py-3">Completed</th>
                        <th class="px-4 py-3">Modify</th>
                    </tr>
                    </thead>

                    <tbody class="divide-y divide-gray-200">

                    {% for task in tasks %}

                        <tr
                                class="hover:bg-gray-50 transition hover:cursor-pointer task-row"
                                data-href="/tasks/{{ task.id }}"
                        >

                            <td class="px-4 py-3 font-medium text-gray-900">
                                {{ task.id }}
                            </td>

                            <td class="px-4 py-3 font-semibold">
                                {{ task.title }}
                            </td>

                            <td class="px-4 py-3">
                            <span class="px-2 py-1 text-xs font-semibold rounded-full bg-{{ priorityColours[task.priority] }}-100 text-{{ priorityColours[task.priority] }}-600">
                                {{ priorities[task.priority]|capitalize }}
                            </span>
                            </td>

                            <td class="px-4 py-3">
                            <span class="px-2 py-1 text-xs font-semibold rounded-full bg-{{ statusColours[task.status] }}-100 text-{{ statusColours[task.status] }}-600">
                                {{ statuses[task.status]|capitalize }}
                            </span>
                            </td>

                            <td class="px-4 py-3 w-48">
                                <div class="w-full bg-gray-200 rounded-full h-2">
                                    <div
                                            class="bg-blue-500 h-2 rounded-full"
                                            style="width: {{ task.progress }}%">
                                    </div>
                                </div>
                                <span class="text-xs text-gray-500">
                                {{ task.progress }}%
                            </span>
                            </td>

                            <td class="px-4 py-3">
                                {{ task.createdAt|date('d/m/y') }}
                            </td>

                            <td class="px-4 py-3">
                                {{ task.completedAt|date('d/m/y') ?: '-' }}
                            </td>

                            <td class="px-1 py-3 inline-flex no-row-click">

                                <button command="show-modal" commandfor="dialog-open{{ task.id ? '-' ~ task.id }}" class="group hover:cursor-pointer hover:bg-orange-100 h-8 w-8 rounded-md flex items-center justify-center mr-6">
                                    <i class="fa-solid fa-pencil group-hover:text-orange-500 transition-colors"></i>
                                </button>

                                <button command="show-modal" commandfor="dialog-delete-{{ task.id }}" class="group hover:cursor-pointer hover:bg-red-100 h-8 w-8 rounded-md flex items-center justify-center">
                                    <i class="fa-solid fa-trash group-hover:text-red-500 transition-colors"></i>
                                </button>

                                {% include "modals/create-task.html.twig" with {
                                    'task': task,
                                    'labels': {
                                        title: 'Edit Task',
                                        submit: 'Save'
                                    },
                                    'route': 'tasks/update'
                                } %}

                                {% include "modals/delete-task.html.twig" with { 'task': task } %}
                            </td>
                        </tr>

                    {% else %}

                        <tr>
                            <td colspan="8" class="text-center py-6 text-gray-500">
                                No tasks found.
                            </td>
                        </tr>

                    {% endfor %}

                    </tbody>
                </table>

                {% include "modals/create-task.html.twig" %}

            </div>
        </div>
    </div>

    <script>

        document.querySelectorAll(".task-row").forEach(row => {
            row.addEventListener("click", function (e) {
                if (e.target.closest(".no-row-click")) return;

                const url = this.dataset.href;

                if (e.ctrlKey || e.metaKey) {
                    window.open(url, "_blank");
                } else {
                    window.location.href = url;
                }

            });

        });

        const slider = {
            element: document.getElementById('progress'),
            value: document.getElementById('progressvalue')
        }

        if (slider.element) {
            slider.element.addEventListener('input', function (e) {
                slider.value.innerText = e.srcElement.value + '%';
            })
        }

    </script>

{% endblock %}