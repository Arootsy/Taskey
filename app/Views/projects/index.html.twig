{% extends "layouts/layout.html.twig" %}
{% block title %}
    <title>Projects</title>
{% endblock %}

{% block content %}
    <script src="https://cdn.jsdelivr.net/npm/@tailwindplus/elements@1" type="module"></script>

    <!-- Breadcrumb -->
    <ol class="flex items-center whitespace-nowrap px-24 py-12">
        <li class="inline-flex items-center">
            <a class="flex items-center text-sm text-muted-foreground-1 hover:text-primary-focus focus:outline-hidden focus:text-primary-focus" href="/">
                Home
            </a>
            <svg class="shrink-0 mx-2 size-4 text-muted-foreground" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </li>
        <li class="inline-flex items-center text-sm font-semibold text-foreground truncate" aria-current="page">
            Projects
        </li>
    </ol>

    <div class="px-24 py-8">
        <!-- Header + Create button -->
        <div class="flex justify-between mb-6">
            <h1 class="text-3xl font-bold text-gray-800">Projects</h1>
            <button command="show-modal" commandfor="dialog-open" class="bg-blue-500 text-white px-6 py-3 rounded-md hover:cursor-pointer hover:bg-blue-600 duration-500">
                Create Project
            </button>
        </div>

        <!-- Projects Table -->
        <div class="bg-white shadow-lg rounded-2xl overflow-hidden">
            <div class="overflow-x-auto">
                <table class="table-auto w-full text-sm text-left text-gray-600">
                    <thead class="bg-gray-100 text-xs uppercase tracking-wider text-gray-700">
                    <tr>
                        <th class="px-4 py-3">ID</th>
                        <th class="px-4 py-3">Title</th>
                        <th class="px-4 py-3">Description</th>
                        <th class="px-4 py-3">Progress</th>
                        <th class="px-4 py-3">Created</th>
                        <th class="px-4 py-3">Completed</th>
                        <th class="px-4 py-3">Modify</th>
                    </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200">
                    {% for project in projects %}
                        <tr class="hover:bg-gray-50 transition hover:cursor-pointer">
                            <td class="px-4 py-3 font-medium text-gray-900" onclick="window.location.href = 'projects/{{ project.id }}'">
                                {{ project.id }}
                            </td>

                            <td class="px-4 py-3 font-semibold" onclick="window.location.href = 'projects/{{ project.id }}'">
                                {{ project.title }}
                            </td>

                            <td class="px-4 py-3" onclick="window.location.href = 'projects/{{ project.id }}'">
                                {{ project.description|slice(0, 50) ~ (project.description|length > 50 ? '...' : '') }}
                            </td>

                            <td class="px-4 py-3 w-48" onclick="window.location.href = 'projects/{{ project.id }}'">
                                <div class="w-full bg-gray-200 rounded-full h-2">
                                    <div class="bg-blue-500 h-2 rounded-full" style="width: {{ project.progress }}%"></div>
                                </div>
                                <span class="text-xs text-gray-500">{{ project.progress }}%</span>
                            </td>

                            <td class="px-4 py-3" onclick="window.location.href = 'projects/{{ project.id }}'">
                                {{ project.createdAt|date('d/m/y') }}
                            </td>

                            <td class="px-4 py-3" onclick="window.location.href = 'projects/{{ project.id }}'">
                                {{ project.completedAt|date('d/m/y') ?: '-' }}
                            </td>

                            <td class="px-1 py-3 inline-flex">
                                <button command="show-modal" commandfor="dialog-open{{ project.id ? '-' ~ project.id }}" class="group hover:cursor-pointer hover:bg-orange-100 h-8 w-8 rounded-md flex items-center justify-center mr-6">
                                    <i class="fa-solid fa-pencil group-hover:text-orange-500 transition-colors"></i>
                                </button>
                                <button command="show-modal" commandfor="dialog-delete" class="group hover:cursor-pointer hover:bg-red-100 h-8 w-8 rounded-md flex items-center justify-center">
                                    <i class="fa-solid fa-trash group-hover:text-red-500 transition-colors"></i>
                                </button>

                                {% include "modals/create-task.html.twig" with { 'project': project, 'labels': {
                                    title: 'Edit Project',
                                    submit: 'Save'
                                }, 'route': 'projects/update' } %}
                                {% include "modals/delete-task.html.twig" with { 'project': project } %}
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="7" class="text-center py-6 text-gray-500">
                                No projects found.
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>

                {% include "modals/create-task.html.twig" %}
            </div>
        </div>
    </div>

    <script>
        const slider = {
            element: document.getElementById('progress'),
            value: document.getElementById('progressvalue')
        }

        if (slider.element) {
            slider.element.addEventListener('input', function (e) {
                slider.value.innerText = e.srcElement.value + '%';
            })
        }
    </script>
{% endblock %}